{
  "compilerOptions": {
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "declaration": false,
    "experimentalDecorators": true,
    "lib": ["dom", "es2017"],
    "moduleResolution": "node",
    "module": "esnext",
    "target": "es2017",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react",
    "jsxFactory": "h",
    // This is not great, but it's the only way I could find to get around the error "Duplicate identifier 'shader'.",
    // caused by Stencil and PixiJS both defining modules with the same default export for GLSL shaders.
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
